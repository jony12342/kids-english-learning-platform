# DeepSeek AI API
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_API_URL=https://api.deepseek.com/v1

# Supabase Configuration
# Get these from your Supabase project settings: https://supabase.com/dashboard
